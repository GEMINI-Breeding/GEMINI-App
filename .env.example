# Variables loaded by frontend/tests/config.ts for Playwright E2E tests.
# Copy to .env and adjust as needed. The defaults below match the
# backend's FIRST_SUPERUSER / FIRST_SUPERUSER_PASSWORD defaults in
# backend/app/core/config.py, and VITE_API_URL matches the backend's
# default bind address.

FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=adminpassword
VITE_API_URL=http://localhost:8000
