# Mapbox Token (optional)
REACT_APP_MAPBOX_TOKEN=

# Port Configuration
REACT_APP_FRONT_PORT=3000
REACT_APP_FLASK_PORT=5000
REACT_APP_TILE_SERVER_PORT=8091

# Backend Mode: "flask" (default), "framework", or "hybrid"
# Use "npm run gemini" for flask mode, "npm run gemini:framework" for framework mode
REACT_APP_BACKEND_MODE=flask

# gemini-framework backend (used when BACKEND_MODE is "framework" or "hybrid")
REACT_APP_FRAMEWORK_PORT=7777
REACT_APP_FRAMEWORK_HOST=localhost

# Application Data Directory (Flask mode only)
REACT_APP_APP_DATA=~/GEMINI-App-Data
