# Leave VITE_API_URL empty so /api/* uses relative URLs and goes through the
# Vite dev proxy (configured in vite.config.ts to forward /api to :7777).
# Setting an absolute URL here was the FastAPI-era pattern; under GEMINIbase
# any non-empty value bypasses the proxy and breaks /api/* fetches.
VITE_API_URL=
MAILCATCHER_HOST=http://localhost:1080

APP_DATA_ROOT=$HOME/GEMI-Data
