{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "../scripts/start-backend.sh",
    "dev:full": "concurrently -k -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev\"",
    "build": "tsc -p tsconfig.build.json && vite build",
    "lint": "biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true ./",
    "preview": "vite preview",
    "generate-client": "openapi-ts",
    "build:backend": "../backend/build-desktop.sh",
    "tauri": "tauri",
    "tauri:dev": "concurrently -k -n backend,tauri -c blue,magenta \"npm run dev:backend\" \"GDK_BACKEND=x11 tauri dev\"",
    "tauri:build": "npm run build:backend && tauri build"
  },
